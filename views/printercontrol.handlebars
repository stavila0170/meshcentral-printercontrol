<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>Printer Control</title>
    <style>
        :root { color-scheme: light dark; --border:#b8b8b8; --panel:#f5f6f7; --danger:#b42318; --ok:#067647; --accent:#1769aa; }
        * { box-sizing:border-box; }
        body { margin:0; padding:12px; font:13px "Segoe UI",Arial,sans-serif; color:#222; background:#fff; }
        .toolbar,.panel-head,.actions { display:flex; align-items:center; gap:7px; flex-wrap:wrap; }
        .toolbar { padding:10px; border:1px solid var(--border); background:var(--panel); border-radius:6px; }
        .toolbar .spacer { flex:1; }
        button { padding:6px 10px; border:1px solid #999; border-radius:4px; background:#fff; color:#222; cursor:pointer; }
        button:hover:not(:disabled) { border-color:var(--accent); }
        button:disabled { opacity:.45; cursor:not-allowed; }
        button.danger { color:var(--danger); border-color:#d92d20; }
        button.small { padding:3px 7px; font-size:12px; }
        .badge { display:inline-block; padding:3px 8px; border:1px solid #98a2b3; border-radius:999px; font-weight:600; color:#344054; background:#eaecf0; }
        .badge.ok { color:var(--ok); background:#d1fadf; }
        .badge.bad { color:var(--danger); background:#fee4e2; }
        .badge.unknown { color:#344054; background:#eaecf0; border:1px solid #98a2b3; }
        .message { min-height:34px; margin:9px 0; padding:8px 10px; border-radius:4px; background:#eef4ff; }
        .message.error { color:var(--danger); background:#fee4e2; }
        .message.success { color:var(--ok); background:#d1fadf; }
        .panel { margin-top:10px; border:1px solid var(--border); border-radius:6px; overflow:hidden; }
        .panel-head { padding:9px 10px; background:var(--panel); border-bottom:1px solid var(--border); }
        .panel-head h2 { margin:0; font-size:15px; }
        .panel-head .spacer { flex:1; }
        .table-wrap { max-height:420px; overflow:auto; }
        table { width:100%; border-collapse:collapse; }
        th,td { padding:7px 8px; border-bottom:1px solid #ddd; text-align:left; vertical-align:middle; }
        th { position:sticky; top:0; z-index:1; background:#eceff2; }
        tbody tr:hover { background:#f7faff; }
        .empty { padding:20px; color:#666; text-align:center; }
        details { margin-top:10px; border:1px solid var(--border); border-radius:6px; padding:8px 10px; }
        summary { cursor:pointer; font-weight:600; }
        .form-grid { display:grid; grid-template-columns:repeat(4,minmax(140px,1fr)); gap:8px; margin-top:10px; }
        label { display:flex; flex-direction:column; gap:4px; }
        input,select { width:100%; padding:6px; border:1px solid #999; border-radius:4px; background:#fff; color:#222; }
        .form-actions { margin-top:9px; }
        .muted { color:#666; }
        @media (prefers-color-scheme:dark) {
            :root { --border:#555; --panel:#292929; }
            body { color:#eee; background:#1e1e1e; }
            button,input,select { color:#eee; background:#303030; border-color:#666; }
            th { background:#303030; } td,th { border-bottom-color:#444; } tbody tr:hover { background:#26374a; }
            .message { background:#26374a; } .muted { color:#aaa; }
            .badge { color:#f2f4f7; background:#475467; border-color:#667085; }
            .badge.unknown { color:#f2f4f7; background:#475467; border-color:#667085; }
        }
    </style>
</head>
<body onload="printerControlOnLoad()">
    <div class="toolbar">
        <strong>Print Spooler:</strong>
        <span id="spoolerBadge" class="badge unknown">Unknown</span>
        <button id="refreshBtn" onclick="PrinterControl.refresh()">Refresh</button>
        <button data-permission="manage_spooler" onclick="PrinterControl.run('spoolerStart',{})">Start</button>
        <button data-permission="manage_spooler" onclick="PrinterControl.run('spoolerStop',{})">Stop</button>
        <button data-permission="manage_spooler" onclick="PrinterControl.run('spoolerRestart',{})">Restart</button>
        <button class="danger" data-permission="manage_spooler" onclick="PrinterControl.clearQueue()">Clear queue</button>
        <span class="spacer"></span>
        <span id="onlineBadge" class="badge unknown">Checking agent...</span>
    </div>

    <div id="message" class="message">Loading permissions...</div>

    <details id="addPanel">
        <summary>Add TCP/IP printer</summary>
        <div class="form-grid">
            <label>Printer name<input id="addName" maxlength="220" autocomplete="off"></label>
            <label>IP address / DNS<input id="addAddress" maxlength="255" autocomplete="off"></label>
            <label>Installed driver<input id="addDriver" maxlength="220" list="driverList" autocomplete="off"></label>
            <label>Port name (optional)<input id="addPort" maxlength="220" placeholder="IP_192.0.2.10" autocomplete="off"></label>
        </div>
        <datalist id="driverList"></datalist>
        <div class="form-actions">
            <button data-permission="manage_printers" onclick="PrinterControl.addTcpPrinter()">Add printer</button>
            <span class="muted">The driver must already exist on the endpoint.</span>
        </div>
    </details>

    <section class="panel">
        <div class="panel-head"><h2>Printers</h2><span class="spacer"></span><span id="printerCount" class="muted"></span></div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Name</th><th>Status</th><th>Driver</th><th>Port</th><th>Jobs</th><th>Shared</th><th>Actions</th></tr></thead>
                <tbody id="printerRows"><tr><td colspan="7" class="empty">No data loaded.</td></tr></tbody>
            </table>
        </div>
    </section>

    <section class="panel">
        <div class="panel-head"><h2 id="jobsTitle">Print jobs</h2><span class="spacer"></span><button id="jobsRefresh" class="small" disabled onclick="PrinterControl.reloadJobs()">Refresh jobs</button></div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>ID</th><th>Document</th><th>User</th><th>Status</th><th>Pages</th><th>Size</th><th>Actions</th></tr></thead>
                <tbody id="jobRows"><tr><td colspan="7" class="empty">Select a printer to view its queue.</td></tr></tbody>
            </table>
        </div>
    </section>

<script>
"use strict";

var PrinterControl = (function () {
    var state = {
        nodeid: new URLSearchParams(window.location.search).get("nodeid"),
        online: false,
        permissions: [],
        inventory: null,
        selectedPrinter: null,
        preserveSpoolerBadgeOnInventoryFailure: false,
        inventoryRequestInFlight: false,
        permissionsLoaded: false,
        autoRefreshTimer: null
    };

    function hasPermission(name) { return state.permissions.indexOf(name) >= 0; }

    function setMessage(text, kind) {
        var box = document.getElementById("message");
        box.textContent = text || "";
        box.className = "message" + (kind ? " " + kind : "");
    }

    function updateButtons() {
        var buttons = document.querySelectorAll("[data-permission]");
        for (var i = 0; i < buttons.length; i++) {
            buttons[i].disabled = !state.online || !hasPermission(buttons[i].getAttribute("data-permission"));
        }
        document.getElementById("refreshBtn").disabled = !state.online || !hasPermission("can_view");
        document.getElementById("jobsRefresh").disabled = !state.online || !hasPermission("can_view") || !state.selectedPrinter;
    }

    function setSpoolerBadge(status) {
        var badge = document.getElementById("spoolerBadge");
        var value = String(status || "Unknown").trim();
        var normalized = value.toLowerCase();

        badge.textContent = value;
        if (normalized === "running") {
            badge.className = "badge ok";
        } else if (normalized === "stopped") {
            badge.className = "badge bad";
        } else {
            badge.className = "badge unknown";
        }
    }

    function send(operation, params, options) {
        if (!state.nodeid) { setMessage("Missing node identifier.", "error"); return false; }
        options = options || {};

        // Inventory can take longer than the 2-second polling interval. Never
        // start a second request while the previous one is still pending.
        if (operation === "inventory") {
            if (state.inventoryRequestInFlight) {
                if (!options.silent) setMessage("Inventory refresh is already running.");
                return false;
            }
            state.inventoryRequestInFlight = true;
            state.preserveSpoolerBadgeOnInventoryFailure = options.preserveSpoolerBadge === true;
            if (!state.preserveSpoolerBadgeOnInventoryFailure) setSpoolerBadge("Checking...");
        } else if (operation === "spoolerStart") {
            setSpoolerBadge("Starting...");
        } else if (operation === "spoolerStop") {
            setSpoolerBadge("Stopping...");
        } else if (operation === "spoolerRestart") {
            setSpoolerBadge("Restarting...");
        }

        if (!options.silent) setMessage("Running " + operation + "...");
        parent.meshserver.send({
            action: "plugin",
            plugin: "printercontrol",
            pluginaction: operation,
            nodeid: state.nodeid,
            params: params || {}
        });
        return true;
    }

    function textCell(row, value) {
        var cell = document.createElement("td");
        cell.textContent = value == null ? "" : String(value);
        row.appendChild(cell);
        return cell;
    }

    function button(label, permission, callback, danger) {
        var value = document.createElement("button");
        value.type = "button";
        value.className = "small" + (danger ? " danger" : "");
        value.textContent = label;
        value.disabled = !state.online || !hasPermission(permission);
        value.onclick = callback;
        return value;
    }

    function renderInventory(data) {
        state.inventory = data || {};
        var spooler = data && data.spooler ? data.spooler.status : "Unknown";
        setSpoolerBadge(spooler);
        state.preserveSpoolerBadgeOnInventoryFailure = false;

        var drivers = data && Array.isArray(data.drivers) ? data.drivers : [];
        var driverList = document.getElementById("driverList");
        driverList.textContent = "";
        drivers.forEach(function (driver) {
            var option = document.createElement("option");
            option.value = driver.name || "";
            driverList.appendChild(option);
        });

        var printers = data && Array.isArray(data.printers) ? data.printers : [];
        document.getElementById("printerCount").textContent = printers.length + " printer(s)";
        var body = document.getElementById("printerRows");
        body.textContent = "";
        if (!printers.length) {
            var empty = document.createElement("tr");
            var emptyCell = textCell(empty, "No printers found.");
            emptyCell.colSpan = 7;
            emptyCell.className = "empty";
            body.appendChild(empty);
            return;
        }

        printers.forEach(function (printer) {
            var row = document.createElement("tr");
            textCell(row, (printer.default ? "★ " : "") + (printer.name || ""));
            textCell(row, printer.status || "Unknown");
            textCell(row, printer.driverName || "");
            textCell(row, printer.portName || "");
            textCell(row, printer.jobCount || 0);
            textCell(row, printer.shared ? (printer.shareName || "Yes") : "No");
            var actionCell = document.createElement("td");
            actionCell.className = "actions";
            actionCell.appendChild(button("Jobs", "can_view", function () { loadJobs(printer.name); }));
            actionCell.appendChild(button("Test", "manage_printers", function () { send("testPage", { printerName: printer.name }); }));
            actionCell.appendChild(button("Delete", "manage_printers", function () { deletePrinter(printer); }, true));
            row.appendChild(actionCell);
            body.appendChild(row);
        });
    }

    function renderJobs(data) {
        state.selectedPrinter = data ? data.printerName : state.selectedPrinter;
        document.getElementById("jobsTitle").textContent = "Print jobs" + (state.selectedPrinter ? " — " + state.selectedPrinter : "");
        updateButtons();
        var jobs = data && Array.isArray(data.jobs) ? data.jobs : [];
        var body = document.getElementById("jobRows");
        body.textContent = "";
        if (!jobs.length) {
            var empty = document.createElement("tr");
            var emptyCell = textCell(empty, "The queue is empty.");
            emptyCell.colSpan = 7;
            emptyCell.className = "empty";
            body.appendChild(empty);
            return;
        }
        jobs.forEach(function (job) {
            var row = document.createElement("tr");
            textCell(row, job.id);
            textCell(row, job.documentName || "");
            textCell(row, job.userName || "");
            textCell(row, job.jobStatus || "");
            textCell(row, (job.pagesPrinted || 0) + "/" + (job.totalPages || 0));
            textCell(row, job.size == null ? "" : job.size);
            var actions = document.createElement("td");
            actions.className = "actions";
            actions.appendChild(button("Pause", "manage_jobs", function () { jobAction("pauseJob", job.id); }));
            actions.appendChild(button("Resume", "manage_jobs", function () { jobAction("resumeJob", job.id); }));
            actions.appendChild(button("Cancel", "manage_jobs", function () { jobAction("cancelJob", job.id); }, true));
            row.appendChild(actions);
            body.appendChild(row);
        });
    }

    function loadJobs(printerName) {
        state.selectedPrinter = printerName;
        updateButtons();
        send("jobs", { printerName: printerName });
    }

    function jobAction(operation, jobId) {
        if (!state.selectedPrinter) return;
        if (operation === "cancelJob" && !confirm("Cancel print job " + jobId + "?")) return;
        send(operation, { printerName: state.selectedPrinter, jobId: jobId });
    }

    function deletePrinter(printer) {
        if (!confirm("Delete printer '" + printer.name + "'? Print jobs for this printer will also be removed.")) return;
        var deletePort = confirm("Also remove port '" + printer.portName + "' if no other printer uses it?");
        var deleteDriver = false;
        if (hasPermission("manage_drivers")) {
            deleteDriver = confirm("Also remove driver '" + printer.driverName + "' if no other printer uses it?");
        }
        send("deletePrinter", { printerName: printer.name, deletePort: deletePort, deleteDriver: deleteDriver });
    }

    function clearQueue() {
        if (!confirm("Clear ALL queued print jobs on this computer? The Print Spooler will be restarted.")) return;
        send("clearQueue", {});
    }

    function addTcpPrinter() {
        var name = document.getElementById("addName").value.trim();
        var address = document.getElementById("addAddress").value.trim();
        var driverName = document.getElementById("addDriver").value.trim();
        var portName = document.getElementById("addPort").value.trim();
        if (!name || !address || !driverName) { setMessage("Printer name, address and installed driver are required.", "error"); return; }
        var params = { name: name, address: address, driverName: driverName };
        if (portName) params.portName = portName;
        send("addTcpPrinter", params);
    }

    function handleMessage(message) {
        if (!message || message.nodeid && message.nodeid !== state.nodeid) return;

        if (message.type === "permissions") {
            var firstPermissionsResult = !state.permissionsLoaded;
            var wasOnline = state.online;
            state.online = message.online === true;
            state.permissions = Array.isArray(message.permissions) ? message.permissions : [];
            state.permissionsLoaded = true;

            var online = document.getElementById("onlineBadge");
            online.textContent = state.online ? "Agent online" : "Agent offline";
            online.className = "badge " + (state.online ? "ok" : "bad");
            updateButtons();

            if (!hasPermission("can_view")) {
                setMessage("Access denied. Grant the 'View printers' plugin permission for this user, group or device.", "error");
            } else if (!state.online) {
                setSpoolerBadge("Unknown");
                setMessage("MeshAgent is offline.", "error");
            } else if (firstPermissionsResult || !wasOnline) {
                // Initial load or agent reconnection. Periodic permission checks
                // must not start a duplicate inventory request every time.
                refresh(false, firstPermissionsResult === false);
            }
            return;
        }

        if (message.type !== "result") return;

        if (!message.success) {
            if (message.operation === "inventory") {
                state.inventoryRequestInFlight = false;
                if (!state.preserveSpoolerBadgeOnInventoryFailure) setSpoolerBadge("Unknown");
                state.preserveSpoolerBadgeOnInventoryFailure = false;
            } else if (message.operation === "spoolerStart" || message.operation === "spoolerStop" || message.operation === "spoolerRestart") {
                setSpoolerBadge("Unknown");
            }
            setMessage(message.error || "Printer operation failed.", "error");
            return;
        }

        if (message.operation === "inventory") {
            state.inventoryRequestInFlight = false;
            renderInventory(message.data);
            return;
        }

        setMessage((message.operation || "Operation") + " completed.", "success");
        if (message.operation === "jobs") {
            renderJobs(message.data);
        } else if (message.operation === "cancelJob" || message.operation === "pauseJob" || message.operation === "resumeJob") {
            reloadJobs();
        } else if (message.operation === "spoolerStop") {
            setSpoolerBadge("Stopped");
            refresh(true, true);
        } else if (message.operation === "spoolerStart") {
            setSpoolerBadge("Running");
            refresh(true, true);
        } else if (message.operation === "spoolerRestart") {
            setSpoolerBadge("Running");
            refresh(true, true);
        } else {
            refresh(false, true);
        }
    }

    function refresh(preserveSpoolerBadge, silent) {
        if (!state.online || !hasPermission("can_view")) return false;
        return send("inventory", {}, {
            preserveSpoolerBadge: preserveSpoolerBadge === true,
            silent: silent === true
        });
    }

    function reloadJobs() { if (state.selectedPrinter) loadJobs(state.selectedPrinter); }

    function requestPermissions() {
        if (!state.nodeid) return;
        parent.meshserver.send({ action:"plugin", plugin:"printercontrol", pluginaction:"getPermissions", nodeid:state.nodeid });
    }

    function autoRefreshTick() {
        // Do not poll while this iframe/tab is hidden. This avoids unnecessary
        // PowerShell inventory calls when the Printers page is not visible.
        if (document.hidden) return;

        // Refresh Agent online/offline state and, when possible, the printer
        // inventory/Spooler status. refresh() skips overlapping requests.
        requestPermissions();
        refresh(true, true);
    }

    function startAutoRefresh() {
        if (state.autoRefreshTimer != null) return;
        state.autoRefreshTimer = window.setInterval(autoRefreshTick, 2000);
    }

    function stopAutoRefresh() {
        if (state.autoRefreshTimer == null) return;
        window.clearInterval(state.autoRefreshTimer);
        state.autoRefreshTimer = null;
    }

    return {
        requestPermissions: requestPermissions,
        handleMessage: handleMessage,
        refresh: refresh,
        reloadJobs: reloadJobs,
        run: send,
        clearQueue: clearQueue,
        addTcpPrinter: addTcpPrinter,
        startAutoRefresh: startAutoRefresh,
        stopAutoRefresh: stopAutoRefresh
    };
})();

function printerControlOnLoad() {
    if (!parent.pluginHandler.printercontrol) parent.pluginHandler.printercontrol = {};
    parent.pluginHandler.printercontrol.handlePrinterMessage = function (x, message) {
        PrinterControl.handleMessage(message);
    };
    PrinterControl.requestPermissions();
    PrinterControl.startAutoRefresh();
    window.addEventListener("beforeunload", PrinterControl.stopAutoRefresh);
}
</script>
</body>
</html>
